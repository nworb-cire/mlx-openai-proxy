# Server
MLX_PROXY_HOST=0.0.0.0
MLX_PROXY_PORT=8090
MLX_PROXY_LOG_LEVEL=INFO

# Backend
MLX_PROXY_BACKEND_BASE_URL=http://127.0.0.1:8080/v1
MLX_PROXY_BACKEND_TIMEOUT_SECONDS=600
MLX_PROXY_ACTIVE_REQUEST_TIMEOUT_SECONDS=600
MLX_PROXY_MAX_UPSTREAM_CONCURRENCY=2
MLX_PROXY_MAX_QUEUE_SIZE=128

# LM Studio
MLX_PROXY_LM_STUDIO_BIN=/Users/you/.lmstudio/bin/lms
MLX_PROXY_MODEL_CONFIG_PATH=config/models.json

# Metrics
MLX_PROXY_METRICS_DB_PATH=/Users/you/.local/share/mlx-openai-proxy/metrics.db

# Structured output handling
MLX_PROXY_REASONING_VISIBILITY=compatible
MLX_PROXY_SCHEMA_MODE=auto
MLX_PROXY_PHASE2_MAX_TOKENS=1024
MLX_PROXY_PHASE2_TEMPERATURE=0
MLX_PROXY_PHASE2_TOP_P=1
MLX_PROXY_PHASE2_TOP_K=1
MLX_PROXY_MAX_REPAIR_ATTEMPTS=1
MLX_PROXY_FINAL_CHUNK_SIZE=24

# Images
MLX_PROXY_ENABLE_IMAGE_FILE_URLS=true
MLX_PROXY_MAX_INLINE_IMAGE_BYTES=8388608
